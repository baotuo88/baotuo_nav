# 环境变量配置示例文件
# 复制此文件为 .env 并填入实际的值

# ============================================
# 后台管理员配置（服务端变量）
# ============================================

# 管理员登录密码
ADMIN_PASSWORD=your_admin_password_here

# 建议单独设置一个会话签名密钥，长度尽量长一些
ADMIN_SESSION_SECRET=replace_with_a_long_random_string

# GitHub API 配置（用于后台读写仓库）
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=baotuo88
GITHUB_REPO=baotuo_nav
GITHUB_BRANCH=master

# ============================================
# 前台访问保护（可选，前端变量）
# ============================================

# 首页访问保护开关，任意非空且不为 false/0/off/no 即启用
VITE_OPEN_LOCK=true

# 前台访问密码
VITE_OPEN_LOCK_PASSWORD=your_public_lock_password

# ============================================
# 使用说明
# ============================================

# 1. 管理员后台现在通过同源 /api/admin 接口读写 GitHub
# 2. ADMIN_PASSWORD / ADMIN_SESSION_SECRET / GITHUB_TOKEN 只应保存在服务端环境变量中
# 3. 本地开发时，Vite 会读取当前 .env 里的这些变量
# 4. 如果使用 Vercel 或 Cloudflare Pages，请在平台环境变量里设置这些值
# 5. VITE_OPEN_LOCK 只用于首页访问门槛，不要与后台管理员密码复用
